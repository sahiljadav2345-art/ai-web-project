# MongoDB Connection String
MONGO_URI=mongodb+srv://youruser:yourpassword@cluster.mongodb.net/mockprep

# JWT Secret Key (use any random long string)
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long

# JWT Expiry
JWT_EXPIRE=7d

# Email Config (Gmail example)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=youremail@gmail.com
EMAIL_PASS=your_gmail_app_password

# Google Gemini API Key (free at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Frontend URL (for password reset email link)
FRONTEND_URL=http://localhost:5173

# Server Port
PORT=5000
